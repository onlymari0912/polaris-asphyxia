//DATA//
  profile: DB.FindOne(refid, { collection: 'profile' })
  scores: DB.Find(refid, { collection: 'score_aggregate' })

- const profileData = profile || {};
- const scoreData = Array.isArray(scores) ? scores : [];

style.
  .polaris-profile {
    --polaris-soft: #f6f8fb;
    --polaris-text: #273142;
    color: var(--polaris-text);
  }
  .polaris-summary {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    margin-bottom: 1rem;
  }
  .polaris-summary .box {
    box-shadow: none;
    margin-bottom: 0;
  }
  .polaris-summary .heading {
    color: #6b778c;
    letter-spacing: 0;
  }
  .polaris-summary .title {
    color: var(--polaris-text);
    margin-bottom: 0;
  }
  .polaris-toolbar {
    align-items: start;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: minmax(14rem, 1fr) repeat(4, minmax(9rem, auto));
    margin-bottom: 1rem;
  }
  .polaris-score-table {
    font-size: 0.86rem;
  }
  .polaris-score-table th {
    white-space: nowrap;
  }
  .polaris-score-table td {
    vertical-align: top;
  }
  .polaris-score-table td.polaris-score-data {
    padding: 0;
    text-align: left;
    vertical-align: middle;
  }
  .polaris-score-table td.polaris-score-data.is-empty {
    color: #9aa4b2;
    padding: 0.5rem 0.75rem;
  }
  .polaris-score-table .song-title {
    font-weight: 700;
  }
  .polaris-song-cell {
    align-items: center;
    display: flex;
    gap: 0.65rem;
    min-width: 14rem;
  }
  .polaris-jacket {
    aspect-ratio: 1;
    background: #e8edf3;
    flex: 0 0 auto;
    height: 3.2rem;
    object-fit: cover;
    width: 3.2rem;
  }
  .polaris-score-table .song-credit {
    color: #7b8798;
    font-size: 0.78rem;
  }
  .polaris-score-button {
    all: unset;
    box-sizing: border-box;
    cursor: pointer;
    display: block;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    min-height: 2.25rem;
    padding: 0.5rem 0.75rem;
    text-align: left;
    width: 100%;
  }
  .polaris-score-button:focus-visible {
    outline: 2px solid #3273dc;
    outline-offset: -2px;
  }
  .polaris-score-data.status-none {
    background: #e8edf3;
    color: #637083;
  }
  .polaris-score-data.status-try {
    background: #fff2cc;
    color: #7a5a00;
  }
  .polaris-score-data.status-success {
    background: #dff5e7;
    color: #217344;
  }
  .polaris-score-data.status-fc {
    background: #d9ecff;
    color: #0057c2;
  }
  .polaris-score-data.status-ap {
    background: #f2e6ff;
    color: #6b3ca0;
  }
  .polaris-detail-table th {
    color: #6b778c;
    width: 12rem;
  }
  .polaris-modal-head {
    align-items: center;
    gap: 0.75rem;
  }
  .polaris-modal-heading {
    align-items: center;
    display: flex;
    flex: 1 1 auto;
    gap: 0.85rem;
    min-width: 0;
  }
  .polaris-modal-jacket {
    flex: 0 0 auto;
  }
  .polaris-modal-jacket .polaris-jacket {
    height: 4rem;
    width: 4rem;
  }
  .polaris-modal-title-text {
    min-width: 0;
  }
  .polaris-modal-title-text .modal-card-title {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .polaris-difficulty-tabs {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.85rem;
    overflow-x: auto;
  }
  .polaris-difficulty-tab {
    background: #eef3f8;
    border: 1px solid #dce4ee;
    color: #637083;
    cursor: pointer;
    flex: 0 0 auto;
    font-size: 0.78rem;
    font-weight: 800;
    padding: 0.45rem 0.7rem;
  }
  .polaris-difficulty-tab.is-active {
    background: #273142;
    border-color: #273142;
    color: #fff;
  }
  .polaris-difficulty-tab:disabled {
    color: #a0a9b6;
    cursor: not-allowed;
    opacity: 0.65;
  }
  .polaris-detail-status {
    font-weight: 700;
  }
  .polaris-detail-status.none {
    color: #637083;
  }
  .polaris-detail-status.try {
    color: #7a5a00;
  }
  .polaris-detail-status.success {
    color: #217344;
  }
  .polaris-detail-status.fc {
    color: #0057c2;
  }
  .polaris-detail-status.ap {
    color: #6b3ca0;
  }
  #polaris-score-modal {
    align-items: flex-start;
    padding-top: 4rem;
  }
  #polaris-score-modal .modal-card {
    max-height: calc(100vh - 5rem);
  }
  #polaris-score-modal .modal-card-body {
    overflow-y: auto;
  }
  .polaris-detail-task {
    border-top: 1px solid #e6ebf2;
    margin-top: 1rem;
    padding-top: 1rem;
  }
  .polaris-detail-task-title {
    color: #273142;
    font-size: 0.95rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }
  .polaris-detail-task-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }
  .polaris-detail-task-item {
    background: #f8fafc;
    padding: 0.75rem;
  }
  .polaris-detail-task-head {
    align-items: baseline;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    margin-bottom: 0.55rem;
  }
  .polaris-detail-task-label {
    color: #68758a;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .polaris-detail-task-value {
    font-weight: 800;
    text-align: right;
  }
  .polaris-detail-task-track {
    background: #e1e7ef;
    height: 0.65rem;
    overflow: hidden;
    position: relative;
  }
  .polaris-detail-task-bar {
    padding-bottom: 1rem;
    position: relative;
  }
  .polaris-detail-task-track .polaris-detail-task-fill {
    display: block;
    height: 100%;
  }
  .polaris-detail-task-track .polaris-detail-task-marker {
    background: #fff;
    bottom: 0;
    opacity: 0.9;
    position: absolute;
    top: 0;
    width: 2px;
  }
  .polaris-detail-task-track .polaris-detail-task-marker:nth-child(2) {
    left: 25%;
  }
  .polaris-detail-task-track .polaris-detail-task-marker:nth-child(3) {
    left: 50%;
  }
  .polaris-detail-task-track .polaris-detail-task-marker:nth-child(4) {
    left: 75%;
  }
  .polaris-detail-task-track .polaris-detail-task-marker.is-achieved {
    background: #273142;
    opacity: 0.45;
  }
  .polaris-detail-task-track.likes .polaris-detail-task-fill {
    background: #ffca7a;
  }
  .polaris-detail-task-track.achievement .polaris-detail-task-fill {
    background: #7cc7ff;
  }
  .polaris-detail-task-track.combo .polaris-detail-task-fill {
    background: #b69cff;
  }
  .polaris-detail-task-track.success .polaris-detail-task-fill {
    background: #75d69c;
  }
  .polaris-detail-task-point {
    color: #637083;
    font-size: 0.68rem;
    font-weight: 800;
    overflow: hidden;
    padding-right: 0.35rem;
    position: absolute;
    text-align: right;
    text-overflow: ellipsis;
    top: 0.78rem;
    white-space: nowrap;
  }
  .polaris-detail-task-point.is-achieved {
    color: #273142;
  }
  .polaris-empty {
    padding: 2rem;
    text-align: center;
  }
  .polaris-score-pager {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: space-between;
    margin-top: 0.75rem;
  }
  .polaris-score-page-info {
    color: #68758a;
    font-size: 0.85rem;
    font-weight: 700;
  }
  @media (max-width: 980px) {
    .polaris-toolbar {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 680px) {
    .polaris-toolbar {
      grid-template-columns: 1fr;
    }
    .polaris-detail-task-grid {
      grid-template-columns: 1fr;
    }
    .polaris-score-table {
      font-size: 0.8rem;
    }
  }

.polaris-profile
  .card
    .card-header
      p.card-header-title
        span.icon
          i.mdi.mdi-music-box-multiple
        | SCORE
    .card-content
      .level
        .level-left
          .level-item
            div
              p.heading 플레이어
              p.title.is-5= profileData.name || 'PLAYER'
        .level-right
          .level-item
            span.tag.is-light RefID #{refid}
          if profileData.usrId != null
            .level-item
              span.tag.is-info.is-light usr_id #{profileData.usrId}

      .polaris-summary
        .box
          p.heading 기록된 곡
          p.title.is-5#polaris-summary-songs -
        .box
          p.heading 기록된 보면
          p.title.is-5#polaris-summary-charts -
        .box
          p.heading 총 플레이
          p.title.is-5#polaris-summary-plays -
        .box
          p.heading Success 비율
          p.title.is-5#polaris-summary-success-rate -
        .box
          p.heading Full Combo
          p.title.is-5#polaris-summary-fc -
        .box
          p.heading All Perfect
          p.title.is-5#polaris-summary-ap -

      .polaris-toolbar
        .field
          label.label 검색
          .control.has-icons-left
            input.input#polaris-score-search(type="search" placeholder="곡명, 작곡가, 이펙터")
            span.icon.is-left
              i.mdi.mdi-magnify
        .field
          label.label 난이도
          .control
            .select.is-fullwidth
              select#polaris-difficulty-filter
                option(value="all") 전체
                option(value="0") Easy
                option(value="1") Normal
                option(value="2") Hard
                option(value="3") Influence
                option(value="4") Polar
        .field
          label.label 상태
