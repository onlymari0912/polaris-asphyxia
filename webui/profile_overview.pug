//DATA//
  profile: DB.FindOne(refid, { collection: 'profile' })
  scores: DB.Find(refid, { collection: 'score_aggregate' })

- const profileData = profile || {};
- const scoreData = Array.isArray(scores) ? scores : [];

style.
  .polaris-overview {
    color: #243044;
  }
  .polaris-profile-hero {
    align-items: stretch;
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(18rem, 1.35fr) minmax(16rem, 0.85fr);
    margin-bottom: 1rem;
  }
  .polaris-panel {
    background: #f8fafc;
    padding: 1rem;
  }
  .polaris-player-name {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }
  .polaris-muted {
    color: #6b778c;
  }
  .polaris-grade-band {
    align-items: center;
    display: flex;
    gap: 0.85rem;
  }
  .polaris-grade-main {
    flex: 1;
    min-width: 12rem;
  }
  .polaris-grade-mark {
    align-items: center;
    color: #1e2635;
    display: flex;
    font-size: 1.1rem;
    font-weight: 800;
    justify-content: center;
    min-height: 3.5rem;
    min-width: 7.5rem;
  }
  .polaris-grade-mark.is-next {
    justify-content: flex-end;
  }
  .polaris-grade-mark[hidden] {
    display: none;
  }
  .polaris-grade-mark img {
    display: block;
    max-height: 4rem;
    max-width: 7rem;
    object-fit: contain;
  }
  .polaris-skill-value {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }
  .polaris-grade-progress {
    background: #d9e0ea;
    height: 1.45rem;
    margin-top: 0.6rem;
    overflow: hidden;
    position: relative;
  }
  .polaris-grade-progress span {
    display: block;
    height: 100%;
  }
  .polaris-grade-progress-label {
    align-items: center;
    bottom: 0;
    color: #1e2635;
    display: flex;
    font-size: 0.78rem;
    font-weight: 800;
    justify-content: center;
    left: 0;
    padding: 0 0.45rem;
    pointer-events: none;
    position: absolute;
    right: 0;
    text-align: center;
    top: 0;
  }
  .polaris-summary-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    margin-bottom: 1rem;
  }
  .polaris-stat {
    background: #ffffff;
    padding: 0.85rem;
  }
  .polaris-stat .heading {
    color: #68758a;
    letter-spacing: 0;
    margin-bottom: 0.25rem;
  }
  .polaris-stat .value {
    font-size: 1.25rem;
    font-weight: 800;
  }
  .polaris-profile-table th {
    color: #68758a;
    width: 14rem;
  }
  .polaris-last-track {
    align-items: center;
    display: flex;
    gap: 0.65rem;
  }
  .polaris-last-jacket {
    aspect-ratio: 1;
    background: #e8edf3;
    flex: 0 0 auto;
    height: 3.2rem;
    object-fit: cover;
    width: 3.2rem;
  }
  .polaris-deck-list {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
  .polaris-deck {
    background: #ffffff;
    padding: 0.85rem;
  }
  .polaris-deck.is-selected {
    background: #eef7f4;
  }
  @media (max-width: 860px) {
    .polaris-profile-hero {
      grid-template-columns: 1fr;
    }
  }

