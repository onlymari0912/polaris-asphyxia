//DATA//
  profile: DB.FindOne(refid, { collection: 'profile' })
  scores: DB.Find(refid, { collection: 'score_aggregate' })

- const profileData = profile || {};
- const scoreData = Array.isArray(scores) ? scores : [];

style.
  .polaris-pa {
    color: #243044;
  }
  .polaris-pa-head {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(18rem, 1fr) minmax(18rem, 1fr);
    margin-bottom: 1rem;
  }
  .polaris-pa-panel {
    background: #f8fafc;
    padding: 1rem;
  }
  .polaris-pa-skill {
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
  }
  .polaris-grade-line {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }
  .polaris-grade-emblem {
    align-items: center;
    display: flex;
    min-height: 4.25rem;
    min-width: 7rem;
  }
  .polaris-grade-emblem.is-next {
    justify-content: flex-end;
  }
  .polaris-grade-image {
    display: block;
    max-height: 4rem;
    max-width: 7rem;
    object-fit: contain;
  }
  .polaris-grade-emblem[hidden],
  .polaris-grade-image[hidden],
  .polaris-grade-chip[hidden] {
    display: none;
  }
  .polaris-grade-chip {
    color: #1e2635;
    font-weight: 800;
    min-width: 7rem;
    padding: 0.55rem 0.75rem;
    text-align: center;
  }
  .polaris-grade-meter {
    background: #d9e0ea;
    flex: 1;
    height: 1.45rem;
    overflow: hidden;
    position: relative;
  }
  .polaris-grade-meter span {
    display: block;
    height: 100%;
  }
  .polaris-grade-meter-label {
    align-items: center;
    bottom: 0;
    color: #1e2635;
    display: flex;
    font-size: 0.78rem;
    font-weight: 800;
    justify-content: center;
    left: 0;
    padding: 0 0.45rem;
    pointer-events: none;
    position: absolute;
    right: 0;
    text-align: center;
    top: 0;
  }
  .polaris-pa-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
  }
  .polaris-pa-stat {
    background: #ffffff;
    padding: 0.85rem;
  }
  .polaris-pa-stat .heading {
    color: #68758a;
    letter-spacing: 0;
    margin-bottom: 0.25rem;
  }
  .polaris-pa-stat .value {
    font-size: 1.25rem;
    font-weight: 800;
  }
  .polaris-pa-stat .value.is-small {
    font-size: 1rem;
    line-height: 1.25;
  }
  .polaris-pa-note {
    color: #68758a;
    margin-top: 0.6rem;
  }
  .polaris-pa-toolbar {
    align-items: start;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: minmax(14rem, 1fr) repeat(3, minmax(10rem, auto));
    margin-bottom: 1rem;
  }
  .polaris-pa-toolbar .field {
    margin-bottom: 0;
  }
  .polaris-pa-table {
    font-size: 0.86rem;
  }
  .polaris-pa-table th {
    white-space: nowrap;
  }
  .polaris-pa-table tbody tr.is-b30 td {
    background: #e8f7ed;
  }
  .polaris-pa-table tbody tr.is-outside td {
    background: #f8fafc;
  }
  .polaris-pa-table .rank {
    font-weight: 800;
  }
  .polaris-pa-song {
    align-items: center;
    display: flex;
    gap: 0.65rem;
    min-width: 14rem;
  }
  .polaris-pa-jacket {
    aspect-ratio: 1;
    background: #e8edf3;
    flex: 0 0 auto;
    height: 3.2rem;
    object-fit: cover;
    width: 3.2rem;
  }
  .polaris-pa-table .skill {
    font-weight: 800;
  }
  .polaris-pa-table .muted {
    color: #748096;
    font-size: 0.78rem;
  }
  .polaris-pa-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .polaris-pa-legend span {
    align-items: center;
    display: inline-flex;
    font-size: 0.8rem;
    font-weight: 700;
    gap: 0.4rem;
  }
  .polaris-pa-legend span::before {
    content: "";
    display: inline-block;
    height: 0.75rem;
    width: 1.4rem;
  }
  .polaris-pa-legend .is-b30::before {
    background: #e8f7ed;
  }
  .polaris-pa-legend .is-outside::before {
    background: #f8fafc;
    border: 1px solid #d9e0ea;
  }
  .polaris-pa-empty {
    color: #748096;
    padding: 2rem;
    text-align: center;
  }
  .polaris-pa-pager {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: space-between;
    margin-top: 0.75rem;
  }
  .polaris-pa-page-info {
    color: #68758a;
    font-size: 0.85rem;
    font-weight: 700;
  }
  @media (max-width: 860px) {
    .polaris-pa-head,
    .polaris-pa-toolbar {
      grid-template-columns: 1fr;
    }
  }

